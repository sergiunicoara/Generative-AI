      "required_answer_terms": ["LEAP", "CFM"],
      "forbidden_terms": ["CFM56", "Pratt"],
      "min_context_precision": 0.75
    },
    {
      "id": "SH-07", "type": "single_hop",
      "question": "What is the status of MCAS Software v2.0 relative to v1.0?",
      "expected_citations": ["boeing-swcr"],
      "required_answer_terms": ["supersedes", "v1.0"],
      "forbidden_terms": ["unknown"],
      "min_context_precision": 0.80
