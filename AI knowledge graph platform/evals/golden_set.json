      "required_answer_terms": ["Southwest"],
      "forbidden_terms": ["Airbus"],
      "min_context_precision": 0.80
    },

    {
      "id": "MH-01", "type": "multi_hop",
      "question": "Trace the full supersession chain from FAA-AD-2024-01-02 back to the 2020 directive.",
