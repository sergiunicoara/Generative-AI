      "required_answer_terms": ["2024", "2022", "2020", "supersedes"],
      "forbidden_terms": ["unknown"],
      "min_context_precision": 0.70,
      "note": "Tests 2-hop transitive SUPERSEDES traversal"
    },
    {
      "id": "MH-02", "type": "multi_hop",
      "question": "What maintenance procedure is required for the engine on the aircraft covered by FAA-AD-2024-01-02?",
