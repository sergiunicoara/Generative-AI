{
  "version": "2.0",
  "tenant": "aerospace",
  "description": "Golden evaluation set for the GraphRAG aerospace regulatory corpus. 40 questions across single-hop, multi-hop, contradiction, authority-chain, inference, and negative retrieval types.",
  "thresholds": {
    "min_context_precision": 0.70,
    "min_faithfulness":      0.75,
    "min_relevancy":         0.70,
    "min_citation_recall":   0.60,
    "pass_rate_min":         0.80
  },
  "questions": [

    {
      "id": "SH-01", "type": "single_hop",
      "question": "Which directive supersedes AD-2022?",
      "expected_citations": ["faa-ad-2024"],
      "required_answer_terms": ["FAA-AD-2024", "supersedes"],
      "forbidden_terms": ["unknown", "I don't know"],
      "min_context_precision": 0.80
    },
    {
      "id": "SH-02", "type": "single_hop",
      "question": "Which directive supersedes AD-2020?",
      "expected_citations": ["faa-ad-2022"],
      "required_answer_terms": ["AD-2022", "AD-2020", "supersedes"],
      "forbidden_terms": ["unknown"],
      "min_context_precision": 0.80
    },
    {
      "id": "SH-03", "type": "single_hop",
      "question": "Which regulation body mandated FAA-AD-2024-01-02?",
