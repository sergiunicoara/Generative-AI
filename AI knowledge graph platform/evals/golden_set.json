    },
    {
      "id": "MH-04", "type": "multi_hop",
      "question": "What is the regulatory path from FAA to the maintenance crew for the CFM LEAP-1B engine?",
      "expected_citations": ["faa-ad-2024", "maintenance-manual"],
      "required_answer_terms": ["FAA", "LEAP", "maintenance"],
      "forbidden_terms": [],
      "min_context_precision": 0.65,
      "note": "Multi-hop — designed to trigger agentic IRCoT fallback"
    },
    {
      "id": "MH-05", "type": "multi_hop",
