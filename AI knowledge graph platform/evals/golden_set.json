      "required_answer_terms": ["FAA"],
      "forbidden_terms": ["EASA", "unknown"],
      "min_context_precision": 0.85
    },
    {
      "id": "SH-04", "type": "single_hop",
      "question": "What aircraft type does FAA-AD-2024-01-02 apply to?",
