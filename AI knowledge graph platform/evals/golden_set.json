      "forbidden_terms": ["yes, it is compliant", "no, it is not compliant"],
      "min_context_precision": 0.70,
      "note": "Correct answer surfaces the contradiction, not a binary yes/no"
    },
    {
      "id": "CON-02", "type": "contradiction",
