# ── Google AI ──────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_INGEST_MODEL=gemini-2.0-flash
GEMINI_QUERY_MODEL=gemini-2.0-pro-exp
GEMINI_EMBED_MODEL=text-embedding-004

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrag_dev

# ── RabbitMQ ───────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://graphrag:graphrag_dev@localhost:5672/

# ── TimescaleDB (KPI store) ────────────────────────────────────────────────────
TIMESCALE_URL=postgresql+asyncpg://graphrag:graphrag_dev@localhost:5432/graphrag_kpis

# ── Application ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=development
